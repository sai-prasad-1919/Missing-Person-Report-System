<%- include('../partials/header') %>

<main class="main-content">
  <!-- Hero Section -->
  <section class="hero-section">
    <div class="hero-overlay"></div>
    <div class="hero-content">
      <h1 class="hero-title">Help Us Bring Them Home</h1>
      <p class="hero-subtitle" style="color: rgb(228, 227, 227);">Together we can make a difference in reuniting families</p>
      
      <div class="cta-buttons">
        <a href="/woking/learn-working" class="cta-btn primary">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"></circle>
            <path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"></path>
            <line x1="12" y1="17" x2="12.01" y2="17"></line>
          </svg>
          Learn How It Works
        </a>
      </div>
    </div>
    <div class="hero-scroll-indicator">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M12 5v14"></path>
        <path d="m19 12-7 7-7-7"></path>
      </svg>
    </div>
  </section>
  <!-- Features Section -->
  <section class="features-section">
    <div class="features-grid">
      <div class="feature-card">
        <div class="feature-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"></path>
          </svg>
        </div>
        <h3>Quick Reporting</h3>
        <p>File reports easily and efficiently</p>
        <div class="feature-stats">
          <span class="feature-stat">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"></circle>
              <polyline points="12 6 12 12 16 14"></polyline>
            </svg>
            <span>5 min process</span>
          </span>
        </div>
      </div>
      
      <div class="feature-card">
        <div class="feature-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
          </svg>
        </div>
        <h3>Real-time Updates</h3>
        <p>Stay informed with latest updates</p>
        <div class="feature-stats">
          <span class="feature-stat">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 12h-4l-3 9L9 3l-3 9H2"></path>
            </svg>
            <span>Instant updates</span>
          </span>
        </div>
      </div>
      
      <div class="feature-card">
        <div class="feature-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 15c4.418 0 8-3.582 8-8s-3.582-8-8-8-8 3.582-8 8 3.582 8 8 8z"></path>
          </svg>
        </div>
        <h3>Secure Platform</h3>
        <p>Your information is protected</p>
        <div class="feature-stats">
          <span class="feature-stat">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
            </svg>
            <span>End-to-end encryption</span>
          </span>
        </div>
      </div>
    </div>
  </section>

  <!-- Success Stories Section -->
  <section class="image-gallery">
    <div class="success-stories-container">
      <h2 class="section-title">Success Stories</h2>
      <div class="success-stories-grid">
        <div class="story-card">
          <div class="story-image">
            <img src="/images/family-1.jpg" alt="Family reunion" class="story-img" loading="lazy" />
            <div class="story-overlay"></div>
            <div class="story-badge">Reunited</div>
          </div>
          <div class="story-content">
            <h3>The Heamanth Family</h3>
            <p class="story-quote">"After 3 months of searching, we found our daughter thanks to this platform. The support from volunteers was incredible."</p>
            <div class="story-meta">
              <span class="story-date">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                  <line x1="16" y1="2" x2="16" y2="6"></line>
                  <line x1="8" y1="2" x2="8" y2="6"></line>
                  <line x1="3" y1="10" x2="21" y2="10"></line>
                </svg>
                March 2023
              </span>
            </div>
          </div>
        </div>
        
        <div class="story-card">
          <div class="story-image">
            <img src="/images/family-5.jpg" alt="Emotional reunion" class="story-img" loading="lazy" />
            <div class="story-overlay"></div>
            <div class="story-badge">Reunited</div>
          </div>
          <div class="story-content">
            <h3>The Ravi Krishna Family</h3>
            <p class="story-quote">"The real-time updates kept us informed every step of the way. We're forever grateful to everyone who helped."</p>
            <div class="story-meta">
              <span class="story-date">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                  <line x1="16" y1="2" x2="16" y2="6"></line>
                  <line x1="8" y1="2" x2="8" y2="6"></line>
                  <line x1="3" y1="10" x2="21" y2="10"></line>
                </svg>
                January 2024
              </span>
            </div>
          </div>
        </div>
        
        <div class="story-card">
          <div class="story-image">
            <img src="/images/family-3.png" alt="Happy reunion" class="story-img" loading="lazy" />
            <div class="story-overlay"></div>
            <div class="story-badge">Reunited</div>
          </div>
          <div class="story-content">
            <h3>The Raju Family</h3>
            <p class="story-quote">"The quick reporting system made all the difference.It helped us in finding our son."</p>
            <div class="story-meta">
              <span class="story-date">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                  <line x1="16" y1="2" x2="16" y2="6"></line>
                  <line x1="8" y1="2" x2="8" y2="6"></line>
                  <line x1="3" y1="10" x2="21" y2="10"></line>
                </svg>
                February 2023
              </span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
  
  <!-- CTA Section -->
  <section class="cta-section">
    <div class="cta-particles"></div>
    <div class="cta-content">
      <h2>Ready to Make a Difference?</h2>
      <p>Join our community of volunteers and help reunite families</p>
      <div class="cta-buttons">
        <a href="/register" class="cta-btn primary">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
            <circle cx="8.5" cy="7" r="4"></circle>
            <line x1="20" y1="8" x2="20" y2="14"></line>
            <line x1="23" y1="11" x2="17" y2="11"></line>
          </svg>
          Get Started
        </a>
      </div>
    </div>
  </section>
</main>

<link rel="stylesheet" href="/css/home-index.css">

<script src="/js/home-index.js"></script>

<%- include('../partials/footer') %>
