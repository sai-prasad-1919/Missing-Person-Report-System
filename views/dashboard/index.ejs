<%- include('../partials/header', { isDashboard: true, title: 'Dashboard' }) %>

<main class="dashboard-content">
    <div class="dashboard-container">
        <a href="/login" class="back-button">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M19 12H5M12 19l-7-7 7-7"/>
            </svg>
            <span>Back to login</span>
        </a>
        <div class="dashboard-header">
            <h1>Welcome to <%= userType === 'admin' ? 'Admin' : 'User' %> Dashboard</h1>
        </div>
        <div class="case-cards">
            <a href="/cases/parent" class="case-card">
                <div class="card-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                        <circle cx="9" cy="7" r="4"></circle>
                        <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
                        <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
                    </svg>
                </div>
                <h2>Parent Report Cases</h2>
                <p>View parent-reported missing person cases</p>
                <span class="card-arrow">→</span>
            </a>
            <a href="/cases/public" class="case-card">
                <div class="card-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
                    </svg>
                </div>
                <h2>Public Reported Cases</h2>
                <p>View public-reported missing person cases</p>
                <span class="card-arrow">→</span>
            </a>
        </div>
    </div>
</main>
<link rel="stylesheet" href="/css/user-dashboard.css">