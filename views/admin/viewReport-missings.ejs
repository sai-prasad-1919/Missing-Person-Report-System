<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Missing Person Reports - Missing Person Finder</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="/css/viewReport-missings.css">
</head>
<body>
    <div class="container">
        <a href="/admin/dashboard" class="top-back-button">
            <i class="bi bi-arrow-left"></i>
            Back to Dashboard
        </a>

        <div class="page-header">
            <h1>Missing Person Reports</h1>
        </div>

        <div class="filter-section mb-4">
            <form id="filterForm" class="row g-3">
                <div class="col-md-3">
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-person"></i></span>
                        <input type="text" class="form-control" id="nameFilter" placeholder="Search by name">
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-calendar"></i></span>
                        <input type="number" class="form-control" id="ageFilter" placeholder="Filter by age">
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-geo-alt"></i></span>
                        <input type="text" class="form-control" id="locationFilter" placeholder="Search by location">
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary flex-grow-1">
                            <i class="bi bi-funnel"></i> Filter
                        </button>
                        <button type="button" class="btn btn-secondary" id="clearFilter" style="background-color: rgb(166, 5, 5);">
                            <i class="bi bicircle"></i> Clear
                        </button>
                    </div>
                </div>
            </form>
        </div>

        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
            <% reports.forEach(report => { %>
                <div class="col">
                    <div class="card h-100">
                        <div class="card-image-container">
                        <% if (report.photo) { %>
                            <img src="<%= report.photo.startsWith('http') ? report.photo : '/' + report.photo.replace(/\\/g, '/') %>" class="card-img-top" alt="<%= report.childName %>">
                        <% } else { %>
                            <img src="/images/placeholder.jpg" class="card-img-top" alt="No photo available">
                        <% } %>
                            <div class="card-status-badge">
                                <span class="badge 
                                    <%= report.caseStatus === 'Pending' ? 'bg-warning text-dark' : '' %>
                                    <%= report.caseStatus === 'In Progress' ? 'bg-info text-dark' : '' %>
                                    <%= report.caseStatus === 'Solved' ? 'bg-success' : '' %>
                                    <%= report.caseStatus === 'Closed' ? 'bg-secondary' : '' %>">
                                    <%= report.caseStatus %>
                                </span>
                            </div>
                        </div>

                        <div class="card-body">
                            <h5 class="card-title">
                                <i class="bi bi-person-circle"></i>
                                <%= report.childName %>
                                <span class="age-badge">Age <%= report.age %></span>
                            </h5>

                            <div class="date-info">
                                <div class="date-item">
                                    <span class="date-label">
                                        <i class="bi bi-calendar-date"></i>
                                        Missing Date
                                    </span>
                                    <span class="date-value"><%= new Date(report.lastSeenDate).toLocaleDateString() %></span>
                                </div>
                                <div class="date-item">
                                    <span class="date-label">
                                        <i class="bi bi-clock-history"></i>
                                        Reported Date
                                    </span>
                                    <span class="date-value"><%= new Date(report.createdAt).toLocaleDateString() %></span>
                                </div>
                            </div>

                            <div class="info-section">
                                <h6 class="section-title">Last Seen Information</h6>
                                <div class="info-grid">
                                    <div class="info-item">
                                        <i class="bi bi-geo-alt"></i>
                                        <span><%= report.lastSeenLocation %></span>
                                    </div>
                                    <div class="info-item">
                                        <i class="bi bi-gender-ambiguous"></i>
                                        <span><%= report.gender %></span>
                                    </div>
                                </div>
                            </div>

                            <div class="additional-info-container">
                                <div class="info-section additional-info">
                                    <h6 class="section-title">Last Seen Information (Complete)</h6>
                                    <div class="info-grid">
                                        <div class="info-item">
                                            <i class="bi bi-geo-alt"></i>
                                            <span><%= report.lastSeenLocation %></span>
                                        </div>
                                        <div class="info-item">
                                            <i class="bi bi-calendar"></i>
                                            <span><%= report.lastSeenDate.toDateString() %></span>
                                        </div>
                                        <div class="info-item">
                                            <i class="bi bi-gender-ambiguous"></i>
                                            <span><%= report.gender %></span>
                                        </div>
                                        <div class="info-item">
                                            <i class="bi bi-geo"></i>
                                            <span><%= report.district %></span>
                                        </div>
                                    </div>
                                </div>

                                <div class="info-section additional-info">
                                    <h6 class="section-title">Reporter Information</h6>
                                    <div class="info-grid">
                                        <div class="info-item">
                                            <i class="bi bi-person"></i>
                                            <span><%= report.reporterName %></span>
                                        </div>
                                        <div class="info-item">
                                            <i class="bi bi-person-badge"></i>
                                            <span><%= report.reporterType %></span>
                                        </div>
                                        <div class="info-item">
                                            <i class="bi bi-telephone"></i>
                                            <span><%= report.contactInfo.phone %></span>
                                        </div>
                                        <div class="info-item">
                                            <i class="bi bi-envelope"></i>
                                            <span><%= report.contactInfo.email %></span>
                                        </div>
                                    </div>
                                </div>

                                <div class="info-section additional-info">
                                    <h6 class="section-title">Police Station Information</h6>
                                    <div class="info-grid">
                                        <div class="info-item">
                                            <i class="bi bi-building"></i>
                                            <span><%= report.stationInfo?.name || 'N/A' %></span>
                                        </div>
                                        <div class="info-item">
                                            <i class="bi bi-telephone"></i>
                                            <span><%= report.stationInfo?.phone || 'N/A' %></span>
                                        </div>
                                        <div class="info-item">
                                            <i class="bi bi-geo-alt"></i>
                                            <span><%= report.stationInfo?.location || 'N/A' %></span>
                                        </div>
                                    </div>
                                </div>

                                <div class="info-section additional-info">
                                    <h6 class="section-title">Additional Information</h6>
                                    <p class="description"><%= report.description %></p>
                                </div>
                            </div>

                            <div class="view-more-container">
                                <button class="btn btn-outline-primary view-more-btn" onclick="toggleAdditionalInfo(this)">
                                    <i class="bi bi-chevron-down"></i>
                                    View More
                                </button>
                            </div>
                        </div>

                        <div class="card-footer">
                            <a href="/admin/reports-missing/<%= report._id %>/edit" class="btn btn-outline-primary">
                                <i class="bi bi-pencil-square"></i>
                                Edit Status
                            </a>
                        </div>
                    </div>
                </div>
            <% }) %>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function toggleAdditionalInfo(button) {
            const card = button.closest('.card');
            const additionalInfoContainer = card.querySelector('.additional-info-container');
            const icon = button.querySelector('i');
            
            if (additionalInfoContainer.style.maxHeight) {
                additionalInfoContainer.style.maxHeight = null;
                icon.classList.remove('bi-chevron-up');
                icon.classList.add('bi-chevron-down');
                button.innerHTML = '<i class="bi bi-chevron-down"></i> View More';
            } else {
                additionalInfoContainer.style.maxHeight = additionalInfoContainer.scrollHeight + "px";
                icon.classList.remove('bi-chevron-down');
                icon.classList.add('bi-chevron-up');
                button.innerHTML = '<i class="bi bi-chevron-up"></i> View Less';
            }
        }

        // Filter functionality
        document.getElementById('filterForm').addEventListener('submit', function(e) {
            e.preventDefault();
            
            const nameFilter = document.getElementById('nameFilter').value.toLowerCase();
            const ageFilter = document.getElementById('ageFilter').value;
            const locationFilter = document.getElementById('locationFilter').value.toLowerCase();
            
            const cards = document.querySelectorAll('.card');
            
            cards.forEach(card => {
                const name = card.querySelector('.card-title').textContent.toLowerCase();
                const age = card.querySelector('.age-badge').textContent;
                const location = card.querySelector('.info-item:first-child span').textContent.toLowerCase();
                
                const nameMatch = name.includes(nameFilter);
                const ageMatch = !ageFilter || age.includes(ageFilter);
                const locationMatch = location.includes(locationFilter);
                
                const cardContainer = card.closest('.col');
                if (nameMatch && ageMatch && locationMatch) {
                    cardContainer.style.display = '';
                } else {
                    cardContainer.style.display = 'none';
                }
            });
        });

        // Clear filter functionality
        document.getElementById('clearFilter').addEventListener('click', function() {
            document.getElementById('nameFilter').value = '';
            document.getElementById('ageFilter').value = '';
            document.getElementById('locationFilter').value = '';
            
            const cards = document.querySelectorAll('.card');
            cards.forEach(card => {
                const cardContainer = card.closest('.col');
                cardContainer.style.display = '';
            });
        });
    </script>
</body>
</html>
