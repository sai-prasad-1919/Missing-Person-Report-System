<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Found Person Reports - Missing Person Finder</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/viewReport-found.css">
    <style>
        .btn-custom {
            padding: 0.25rem 0.75rem;
            font-size: 0.875rem;
            line-height: 1.5;
            border-radius: 25px;
        }
        .input-group .btn-custom {
            height: calc(1.5em + 0.5rem + 2px);
        }
    </style>
</head>
<body>
    <div class="container">
        <!-- Back Button -->
        <a href="/admin/dashboard" class="top-back-button">
            <i class="fas fa-arrow-left"></i>
            <span>Back to Dashboard</span>
        </a>

        <!-- Page Header -->
        <div class="page-header">
            <div class="header-content">
                <h1>Found Person Reports</h1>
                <p class="header-subtitle">Review and manage found person cases</p>
            </div>
        </div>

        <!-- Search and Filter Section -->
        <div class="search-section mb-4">
            <div class="row g-3">
                <div class="col-md-8">
                    <label for="searchInput" class="form-label fw-bold mb-2" style="color: #3b82f6; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; font-size: 1.1rem; margin-left: 14px;">Quick Search</label>
                    <div class="input-group">
                        <button class="btn btn-secondary btn-custom me-2" type="button" id="clearButton">
                            Clear
                        </button>
                        <button class="btn btn-info btn-custom" type="button" data-bs-toggle="modal" data-bs-target="#filterModal">
                            <i class="bi bi-funnel"></i>Filter
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Filter Modal -->
        <div class="modal fade" id="filterModal" tabindex="-1" aria-labelledby="filterModalLabel" aria-hidden="true">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title" id="filterModalLabel">Filter Cases</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <form id="filterForm">
                            <div class="mb-3">
                                <label for="filterName" class="form-label">Name</label>
                                <input type="text" class="form-control" id="filterName" placeholder="Enter name">
                            </div>
                            <div class="mb-3">
                                <label for="filterAge" class="form-label">Age</label>
                                <input type="number" class="form-control" id="filterAge" placeholder="Enter age">
                            </div>
                            <div class="mb-3">
                                <label for="filterLocation" class="form-label">Location</label>
                                <input type="text" class="form-control" id="filterLocation" placeholder="Enter location">
                            </div>
                        </form>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary btn-custom" data-bs-dismiss="modal">Close</button>
                        <button type="button" class="btn btn-primary btn-custom" id="applyFilter">Apply Filter</button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Reports Grid -->
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
            <% reports.forEach(report => { %>
                <div class="col">
                    <div class="card h-100">
                        <!-- Image Section -->
                        <div class="card-image-container">
                            <% if (report.photo) { %>
                                <img src="<%= report.photo.startsWith('http') ? report.photo : '/' + report.photo.replace(/\\/g, '/') %>" class="card-img-top" alt="Found person">
                            <% } else { %>
                                <div class="no-image-placeholder">
                                    <i class="fas fa-user-circle"></i>
                                </div>
                            <% } %>
                            
                            <div class="card-status-overlay">
                                <span class="badge 
                                    <%= report.caseStatus === 'Pending' ? 'bg-warning text-dark' : '' %>
                                    <%= report.caseStatus === 'In Progress' ? 'bg-info text-dark' : '' %>
                                    <%= report.caseStatus === 'Solved' ? 'bg-success' : '' %>
                                    <%= report.caseStatus === 'Closed' ? 'bg-secondary' : '' %>">
                                    <%= report.caseStatus %>
                                </span>
                                <% if (report.handedToPolice) { %>
                                    <span class="badge bg-primary">Handed to Police</span>
                                <% } %>
                            </div>
                        </div>

                        <!-- Card Body -->
                        <div class="card-body">
                            <!-- Reporter Info -->
                            <div class="info-section">
                                <h5 class="card-title">
                                    <i class="fas fa-user-circle"></i>
                                    <%= report.childName %>
                                </h5>
                                <div class="date-info">
                                    <div class="date-item">
                                        <i class="far fa-calendar-alt"></i>
                                        <span class="date-value"><strong>Found Date :</strong> <%= new Date(report.createdAt).toLocaleDateString() %></span>
                                    </div>
                                </div>
                            </div>
                            <br>
                            <!-- Person Details -->
                            <div class="details-section">
                                <h6 class="section-title">Person Details</h6>
                                <div class="detail-item">
                                    <i class="fas fa-birthday-cake"></i>
                                    <span><strong>Age:</strong> <%= report.approximateAge %></span>
                                </div>
                                <div class="detail-item">
                                    <i class="fas fa-venus-mars"></i>
                                    <span><strong>Gender:</strong> <%= report.gender %></span>
                                </div>
                                <div class="detail-item">
                                    <i class="fas fa-map-marker-alt"></i>
                                    <span><strong>Found at:</strong> <%= report.foundLocation %></span>
                                </div>
                            </div>

                            <!-- Additional Info (Hidden by default) -->
                            <div class="details-section additional-info" style="display: none;">
                                <h6 class="section-title">Additional Information</h6>
                                <div class="detail-item">
                                    <i class="fas fa-info-circle"></i>
                                    <span><strong>Description:</strong> <%= report.description %></span>
                                </div>
                            </div>

                            <!-- Reporter Info (Hidden by default) -->
                            <div class="details-section additional-info" style="display: none;">
                                <h6 class="section-title">Reporter Information</h6>
                                <div class="detail-item">
                                    <i class="fas fa-user"></i>
                                    <span><strong>Name:</strong> <%= report.reporterName %></span>
                                </div>
                                <div class="detail-item">
                                    <i class="fas fa-phone"></i>
                                    <span><strong>Phone:</strong> <%= report.contactInfo.phone %></span>
                                </div>
                                <div class="detail-item">
                                    <i class="fas fa-envelope"></i>
                                    <span><strong>Email:</strong> <%= report.contactInfo.email %></span>
                                </div>
                            </div>

                            <!-- Station Info (Hidden by default) -->
                            <div class="details-section additional-info" style="display: none;">
                                <h6 class="section-title">Station Information</h6>
                                <div class="detail-item">
                                    <i class="fas fa-building"></i>
                                    <span><strong>Name:</strong> <%= report.stationInfo?.name || 'N/A' %></span>
                                </div>
                                <div class="detail-item">
                                    <i class="fas fa-phone-alt"></i>
                                    <span><strong>Phone:</strong> <%= report.stationInfo?.phone || 'N/A' %></span>
                                </div>
                                <div class="detail-item">
                                    <i class="fas fa-map-marked-alt"></i>
                                    <span><strong>Location:</strong> <%= report.stationInfo?.location || 'N/A' %></span>
                                </div>
                            </div>

                            <!-- View More Button -->
                            <div class="view-more-container">
                                <button class="btn btn-outline-primary view-more-btn" onclick="toggleAdditionalInfo(this)">
                                    <i class="fas fa-chevron-down"></i>
                                    View More
                                </button>
                            </div>
                        </div>

                        <!-- Card Footer -->
                        <div class="card-footer">
                            <a href="/admin/reports-found/<%= report._id %>/edit" class="btn btn-outline-primary">
                                <i class="fas fa-edit"></i>
                                Edit Status
                            </a>
                        </div>
                    </div>
                </div>
            <% }) %>
        </div>
        <br><br>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function toggleAdditionalInfo(button) {
            const card = button.closest('.card');
            const additionalInfo = card.querySelectorAll('.additional-info');
            const icon = button.querySelector('i');
            
            additionalInfo.forEach(info => {
                if (info.style.display === 'none') {
                    info.style.display = 'block';
                    icon.classList.remove('fa-chevron-down');
                    icon.classList.add('fa-chevron-up');
                    button.innerHTML = '<i class="fas fa-chevron-up"></i> View Less';
                } else {
                    info.style.display = 'none';
                    icon.classList.remove('fa-chevron-up');
                    icon.classList.add('fa-chevron-down');
                    button.innerHTML = '<i class="fas fa-chevron-down"></i> View More';
                }
            });
        }

        // Search and Filter Functionality
        document.addEventListener('DOMContentLoaded', function() {
            const clearButton = document.getElementById('clearButton');
            const cards = document.querySelectorAll('.card');
            const filterForm = document.getElementById('filterForm');
            const applyFilter = document.getElementById('applyFilter');

            function clearFilter() {
                filterForm.reset();
                cards.forEach(card => {
                    card.closest('.col').style.display = '';
                });
            }

            function applyFilters() {
                const nameFilter = document.getElementById('filterName').value.toLowerCase().trim();
                const ageFilter = document.getElementById('filterAge').value;
                const locationFilter = document.getElementById('filterLocation').value.toLowerCase().trim();

                cards.forEach(card => {
                    const name = card.querySelector('.card-title').textContent.toLowerCase();
                    const ageText = card.querySelector('.detail-item span').textContent;
                    const ageMatch = ageText.match(/Age:\s*(\d+)/);
                    const location = card.querySelector('.detail-item:nth-child(3) span').textContent.toLowerCase();

                    const nameMatch = !nameFilter || name.includes(nameFilter);
                    const ageMatchResult = !ageFilter || (ageMatch && ageMatch[1] === ageFilter);
                    const locationMatch = !locationFilter || location.includes(locationFilter);

                    const cardContainer = card.closest('.col');
                    if (nameMatch && ageMatchResult && locationMatch) {
                        cardContainer.style.display = '';
                    } else {
                        cardContainer.style.display = 'none';
                    }
                });

                // Close the modal
                const modal = bootstrap.Modal.getInstance(document.getElementById('filterModal'));
                if (modal) {
                    modal.hide();
                }
            }

            // Event Listeners
            clearButton.addEventListener('click', clearFilter);
            applyFilter.addEventListener('click', applyFilters);
        });
    </script>
</body>
</html>
