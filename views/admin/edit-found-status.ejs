<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Found Report Status - Missing Person Finder</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="/css/edit-found-status.css">
</head>
<body>
    <div class="container">
        <!-- Top Back Button -->
        <a href="/admin/viewReports-found" class="top-back-button">
            <i class="bi bi-arrow-left"></i>
            Back to Found Reports
        </a>

        <!-- Page Header -->
        <div class="page-header">
            <div class="header-content">
                <h1>Edit Found Report Status</h1>
                <p class="header-subtitle">Update the status of this found person case</p>
            </div>
        </div>

        <!-- Main Content -->
        <div class="edit-form-container">
            <form action="/admin/reports-found/<%= report._id %>/edit" method="POST" class="edit-form needs-validation" novalidate>
                <!-- Report Details Card -->
                <div class="card report-details-card">
                    <div class="card-body">
                        <h3 class="card-title">
                            <i class="bi bi-person-circle"></i>
                            Report Details
                        </h3>
                        
                        <div class="info-grid">
                            <div class="info-item">
                                <i class="bi bi-person"></i>
                                <div class="info-content">
                                    <label class="info-label">Reporter Name</label>
                                    <p class="info-value"><%= report.reporterName %></p>
                                </div>
                            </div>

                            <div class="info-item">
                                <i class="bi bi-geo-alt"></i>
                                <div class="info-content">
                                    <label class="info-label">Found Location</label>
                                    <p class="info-value"><%= report.foundLocation %></p>
                                </div>
                            </div>

                            <div class="info-item">
                                <i class="bi bi-calendar-date"></i>
                                <div class="info-content">
                                    <label class="info-label">Found Date</label>
                                    <p class="info-value"><%= report.foundDate.toDateString() %></p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Status Update Card -->
                <div class="card status-update-card">
                    <div class="card-body">
                        <h3 class="card-title">
                            <i class="bi bi-pencil-square"></i>
                            Update Status
                        </h3>

                        <div class="form-group">
                            <label for="caseStatus" class="form-label">Case Status</label>
                            <select name="caseStatus" id="caseStatus" class="form-select" required>
                                <option value="Pending" <%= report.caseStatus === 'Pending' ? 'selected' : '' %>>Pending</option>
                                <option value="In Progress" <%= report.caseStatus === 'In Progress' ? 'selected' : '' %>>In Progress</option>
                                <option value="Solved" <%= report.caseStatus === 'Solved' ? 'selected' : '' %>>Solved</option>
                                <option value="Closed" <%= report.caseStatus === 'Closed' ? 'selected' : '' %>>Closed</option>
                            </select>
                        </div>

                        <div class="button-group">
                            <button type="submit" class="btn btn-primary update-btn">
                                <i class="bi bi-check-circle"></i>
                                Update Status
                            </button>
                            <a href="/admin/viewReports-found" class="btn btn-outline-secondary back-btn">
                                <i class="bi bi-arrow-left"></i>
                                Back to Reports
                            </a>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
