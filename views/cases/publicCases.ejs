<!-- views/cases/publicCases.ejs -->
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <link rel="stylesheet" href="/css/parentCases.css">
</head>
<body>
    <%- include('../partials/header', { isDashboard: true, title: 'Public Reported Cases' }) %>
    <div class="container">
        <div class="page-header">
            <h1><%= title %></h1>
        </div>

        <a href="/dashboard" class="back-button">
            <i class="bi bi-arrow-left"></i>
            Back to Dashboard
        </a>

        <div class="search-section mb-4">
            <div class="row g-3">
                <div class="col-md-8">
                    <label for="searchInput" class="form-label fw-bold mb-2" style="color: #3b82f6; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; font-size: 1.1rem; margin-left: 14px;">Quick Search</label>
                    <div class="input-group">
                        <input type="text" id="searchInput" class="form-control rounded-pill me-2" placeholder="Search by name, age, or location...">
                        <button class="btn btn-primary me-2 rounded-pill" type="button" id="searchButton">
                            <i class="bi bi-search"></i>Search
                        </button>
                        <button class="btn btn-secondary me-2 rounded-pill" type="button" id="clearButton">
                            Clear
                        </button>
                        <button class="btn btn-info rounded-pill" type="button" data-bs-toggle="modal" data-bs-target="#filterModal">
                            <i class="bi bi-funnel"></i>Filter
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Filter Modal -->
        <div class="modal fade" id="filterModal" tabindex="-1" aria-labelledby="filterModalLabel" aria-hidden="true">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title" id="filterModalLabel">Filter Cases</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <form id="filterForm">
                            <div class="mb-3">
                                <label for="filterName" class="form-label">Name</label>
                                <input type="text" class="form-control" id="filterName" placeholder="Enter name">
                            </div>
                            <div class="mb-3">
                                <label for="filterAge" class="form-label">Age</label>
                                <input type="number" class="form-control" id="filterAge" placeholder="Enter age">
                            </div>
                            <div class="mb-3">
                                <label for="filterLocation" class="form-label">Location</label>
                                <input type="text" class="form-control" id="filterLocation" placeholder="Enter location">
                            </div>
                        </form>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary rounded-pill" data-bs-dismiss="modal">Close</button>
                        <button type="button" class="btn btn-primary rounded-pill" id="applyFilter">Apply Filter</button>
                    </div>
                </div>
            </div>
        </div>

        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
            <% reports.forEach(report => { %>
                <div class="col">
                    <div class="card h-100">
                        <% if (report.photo) { %>
                            <img src="<%= report.photo.startsWith('http') ? report.photo : '/' + report.photo.replace(/\\/g, '/') %>" class="card-img-top" alt="Reported Person">
                        <% } else { %>
                            <img src="/images/placeholder.jpg" class="card-img-top" alt="No photo available">
                        <% } %>
                        <span class="badge bg-primary position-absolute top-0 end-0 m-2">
                            <%= report.type || 'Found Report' %>
                        </span>

                        <div class="card-body">
                            <h5 class="card-title">
                                <i class="bi bi-person-circle"></i>
                                <%= report.childName || 'Unknown Name' %> (Age <%= report.approximateAge || report.age %>)
                                <h5 style="color: #3b82f6; font-family: var(--font-family);"><b>Last seen Details</b></h5>
                            </h5>

                            <div class="info-grid">
                                <div class="info-item">
                                    <i class="bi bi-geo-alt"></i>
                                    <span><%= report.foundLocation %></span>
                                </div>
                                <div class="info-item">
                                    <i class="bi bi-calendar"></i>
                                    <span><%= report.foundDate ? new Date(report.foundDate).toDateString() : 'N/A' %></span>
                                </div>
                                <div class="info-item">
                                    <i class="bi bi-gender-ambiguous"></i>
                                    <span><%= report.gender %></span>
                                </div>
                                <div class="info-item">
                                    <i class="bi bi-building"></i>
                                    <span><strong id="reported-at">Reported at:</strong> <%= report.stationInfo?.name || 'N/A' %></span>
                                </div>
                                <div class="location-info">
                                    <i class="bi bi-geo-alt"></i>
                                    <span><strong id="location">Station Location: </strong><%= report.stationInfo?.location || 'N/A' %></span>
                                </div>
                            </div>

                            <div class="info-item mb-3">
                                <i class="bi bi-info-circle"></i>
                                <span><%= report.description %></span>
                            </div>

                            <div class="d-flex align-items-center justify-content-between">
                                <span class="badge 
                                    <%= report.caseStatus === 'Pending' ? 'bg-warning text-dark' : '' %>
                                    <%= report.caseStatus === 'In Progress' ? 'bg-info text-dark' : '' %>
                                    <%= report.caseStatus === 'Solved' ? 'bg-success' : '' %>
                                    <%= report.caseStatus === 'Closed' ? 'bg-secondary' : '' %>">
                                    <%= report.caseStatus %>
                                </span>
                            </div>
                        </div>
                    </div>
                </div>
            <% }) %>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const searchInput = document.getElementById('searchInput');
            const searchButton = document.getElementById('searchButton');
            const clearButton = document.getElementById('clearButton');
            const cards = document.querySelectorAll('.card');
            const filterForm = document.getElementById('filterForm');
            const applyFilter = document.getElementById('applyFilter');

            function performSearch() {
                const searchTerm = searchInput.value.toLowerCase().trim();
                
                cards.forEach(card => {
                    const cardContent = card.textContent.toLowerCase();
                    const isVisible = cardContent.includes(searchTerm);
                    card.closest('.col').style.display = isVisible ? '' : 'none';
                });
            }

            function clearFilter() {
                searchInput.value = '';
                filterForm.reset();
                cards.forEach(card => {
                    card.closest('.col').style.display = '';
                });
            }

            function applyFilters() {
                const nameFilter = document.getElementById('filterName').value.toLowerCase().trim();
                const ageFilter = document.getElementById('filterAge').value;
                const locationFilter = document.getElementById('filterLocation').value.toLowerCase().trim();

                cards.forEach(card => {
                    let isVisible = true;
                    const cardContent = card.textContent.toLowerCase();
                    const nameElement = card.querySelector('.card-title');
                    const ageText = nameElement.textContent;
                    const ageMatch = ageText.match(/Age (\d+)/);
                    const locationElements = card.querySelectorAll('.info-item span');

                    // Check name filter
                    if (nameFilter && !nameElement.textContent.toLowerCase().includes(nameFilter)) {
                        isVisible = false;
                    }

                    // Check age filter
                    if (ageFilter && (!ageMatch || ageMatch[1] !== ageFilter)) {
                        isVisible = false;
                    }

                    // Check location filter
                    if (locationFilter) {
                        let locationFound = false;
                        locationElements.forEach(element => {
                            if (element.textContent.toLowerCase().includes(locationFilter)) {
                                locationFound = true;
                            }
                        });
                        if (!locationFound) {
                            isVisible = false;
                        }
                    }

                    card.closest('.col').style.display = isVisible ? '' : 'none';
                });

                // Close the modal
                const modal = bootstrap.Modal.getInstance(document.getElementById('filterModal'));
                modal.hide();
            }

            searchButton.addEventListener('click', performSearch);
            clearButton.addEventListener('click', clearFilter);
            applyFilter.addEventListener('click', applyFilters);
            searchInput.addEventListener('keyup', function(event) {
                if (event.key === 'Enter') {
                    performSearch();
                }
            });
        });
    </script>
</body>
</html>



