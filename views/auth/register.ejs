<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Register - Missing Person Report System</title>
  <link rel="stylesheet" href="/css/register.css" />
</head>
<body>
  <div class="container">
    <div class="register-card">
      <div class="register-header">
        <h1>Create Account</h1>
        <p>Join us in making a difference abhi</p>
      </div>
      <form class="register-form" method="POST" action="/register" id="registerForm">
        <div class="form-group">
          <label for="fullName">Full Name</label>
          <input type="text" id="fullName" name="fullName" required placeholder="Enter your full name">
          <div class="error-message" id="fullNameError"></div>
        </div>
        <div class="form-group">
          <label for="email">Email Address</label>
          <input type="email" id="email" name="email" required placeholder="Enter your email">
          <div class="error-message" id="emailError"></div>
        </div>
        <div class="form-group">
          <label for="password">Password</label>
          <input type="password" id="password" name="password" required placeholder="Create a password">
          <div class="error-message" id="passwordError"></div>
        </div>
        <div class="form-group">
          <label for="phone">Contact Number</label>
          <input type="tel" id="phone" name="phone" required placeholder="Enter your phone number">
          <div class="error-message" id="phoneError"></div>
        </div>
        <!-- <a href="/login" class="register-btn" id="submitBtn">Create Account</a> -->
        <button type="submit" class="register-btn" id="submitBtn">Create Account</button>
        <div class="form-footer">
          <p class="login-text">Already have an account? <a href="/login">Login</a></p>
        </div>
      </form>
      <a href="/" class="back-home">Back to Home</a>
    </div>
  </div>
  <script src="/js/user-register.js"></script>
</body>
</html>
